# Copy this file to ".env" and fill in your Supabase project credentials.
# Find them in your Supabase dashboard: Project Settings → API.
# The anon key is safe to expose in a frontend — it's protected by Row-Level Security.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
